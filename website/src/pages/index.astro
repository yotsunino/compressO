---
import { motion } from "framer-motion";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import {
  getLatestRelease,
  getDownloadAssets,
  fetchGitHubStars,
} from "../utils/github";
import OGImage from "../assets/og.jpg";
import aboutImage from "../assets/about.jpg";
import privateImage from "../assets/private.jpg";
import featuresImage from "../assets/features.jpg";
import heroImage from "../assets/hero.jpg";
import compressoLogo from "../assets/compresso.png";
import HeroAnimatedContent from "../components/HeroAnimatedContent";

const latestRelease = await getLatestRelease();
const downloads = getDownloadAssets(latestRelease.tag_name);
const githubStars = await fetchGitHubStars();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      image={OGImage}
    />
  </head>
  <body>
    <Header />
    <section class="hero w-[95vw]! xl:w-[90vw]!">
      <div class="hero-content">
        <HeroAnimatedContent client:visible />
        <p>
          CompressO is a completely free & open-source video/image
          compression app available for Mac, Windows & Linux.
          <br />
          No signup, no cloud uploads, no tracking. Just powerful compression that runs entirely private
          on your machine.
        </p>
        <div class="cta-group">
          <a href="#downloads" class="btn btn-primary text-zinc-900!">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download
          </a>
          <a
            href="https://github.com/codeforreal1/compressO"
            class="btn btn-secondary"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            View on GitHub <span id="github-stars">{githubStars ? `⭐️ ${githubStars.toLocaleString()}` : ""}</span>
          </a>
        </div>
        <div class="hero-image rounded-[25px]! xl:rounded-[100px]!">
          <img src={heroImage.src} alt="CompressO Interface" />
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">
            Powerful compression.<br />
            <span class="gradient-text">Zero compromise</span>
          </h2>
          <p class="section-subtitle">
            CompressO combines industry-leading compression algorithms with a
            focus on privacy and simplicity.
          </p>
        </div>

        <div class="feature-grid">
          <div class="feature-card">
            <div class="feature-icon">🔒</div>
            <h3>100% Offline</h3>
            <p>
              Your videos never leave your device. All compression happens
              locally on your machine, ensuring complete privacy and security.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3>Lightning Fast</h3>
            <p>Powered by latest FFmpeg. Compress videos within seconds.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>Smart Compression</h3>
            <p>
              Advanced algorithms maintain visual quality while dramatically
              reducing file size. Perfect for sharing and storage.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🎨</div>
            <h3>Simple Interface</h3>
            <p>
              Drag & drop, copy-paste or select videos, compress. No complicated
              settings or technical knowledge required. Just results that work.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🌐</div>
            <h3>Universal Format</h3>
            <p>
              Support for all major video formats including MP4, MOV, AVI, and
              more. Export to any format you need.
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">💎</div>
            <h3>Quality Control</h3>
            <p>
              Fine-tune compression settings to balance file size and quality.
              Preview results before saving.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-text">
            <span class="section-tag">Powerful Features</span>
            <h2>Packed with <span class="gradient-text">everything</span><br />you need!</h2>
            <p>
              CompressO goes beyond simple compression. It's a comprehensive
              video processing tool designed for power users and casual users
              alike.
            </p>
            <ul class="feature-list feature-list-vertical" id="featureList">
              <li>
                <div class="feature-item-content">
                  <strong>Batch Compression</strong>
                  <span
                    >Process multiple videos at once with smart queue management</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>Video Editing</strong>
                  <span
                    >Trim, split, crop, rotate, flip, and zoom videos before
                    compression</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>Video Controls</strong>
                  <span
                    >Customize codec, quality, dimensions, resolution, FPS, and
                    output format</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>Audio Controls</strong>
                  <span
                    >Adjust codec, volume, channels, bitrate, and select audio
                    tracks</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>Clipboard Support</strong>
                  <span
                    >Paste video files or directories directly from clipboard
                    for instant batch processing</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>Drag & Drop</strong>
                  <span
                    >Drop entire folders containing videos for automatic batch
                    compression</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>System Integration</strong>
                  <span
                    >Right-click any video in your file manager and "Open with
                    CompressO"</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>Complete Info</strong>
                  <span
                    >View full video metadata including container, streams,
                    subtitles, and chapters</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>Copy to Clipboard</strong>
                  <span
                    >Copy compressed videos directly to clipboard for easy
                    pasting</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>Metadata Editing</strong>
                  <span
                    >Edit title, artist, album, year, genre, description,
                    copyright, and more</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>Custom Thumbnails</strong>
                  <span
                    >Set custom thumbnails that display as video previews in
                    file managers</span
                  >
                </div>
              </li>
            </ul>
            <button class="show-all-btn" id="showAllBtn"
              >See More Features</button
            >
          </div>
          <div class="showcase-visual">
            <img
              src={featuresImage.src}
              alt="CompressO Features"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-visual">
            <img src={privateImage.src} alt="Privacy First" loading="lazy" />
          </div>
          <div class="showcase-text">
            <span class="section-tag">Privacy First</span>
            <h2>Your videos stay yours.<br />
              <span class="gradient-text">Always!</span>
            </h2>
            <p>
              Unlike online compression services, CompressO never uploads your
              files. No account required. No tracking. No data collection. Just
              pure, local compression that respects your privacy.
            </p>
            <ul class="feature-list">
              <li>No internet connection required</li>
              <li>No user accounts or sign-ups</li>
              <li>No file size limits</li>
              <li>No watermarks</li>
              <li>No tracking</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-text">
            <span class="section-tag">Open Source</span>
            <h2>Free & Open Source.<br />
              <span class="gradient-text">Forever!</span>
            </h2>
            <p>
              CompressO is fully open-source software. The code is available on
              GitHub, so you can audit it, contribute to it, or even fork it for
              your own projects.
            </p>
            <ul class="feature-list">
              <li>MIT License - use it anywhere</li>
              <li>Transparent development on GitHub</li>
              <li>Community-driven features</li>
              <li>Regular updates and improvements</li>
              <li>No hidden costs or premium tiers</li>
            </ul>
            <a
              href="https://github.com/codeforreal1/compressO"
              class="github-link"
              style="margin-top: 24px;"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              Star on GitHub
            </a>
          </div>
          <div class="showcase-visual">
            <img src={aboutImage.src} alt="Open Source" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section cta-section">
      <img
          src={compressoLogo.src}
          alt="Compresso Logo"
          class="w-30 h-auto block  mx-auto!"
      />
      <div class="container">
        <h2 class="gradient-text">Ready to compress your videos/images?</h2>
        <div id="downloads" class="downloads-section">
          <h3>Direct Downloads</h3>
          <div class="downloads-grid">
            <div class="download-column">
              <div class="download-os-header">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="#000000"
                >
                  <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                  <g
                    id="SVGRepo_tracerCarrier"
                    stroke-linecap="round"
                    stroke-linejoin="round"></g>
                  <g id="SVGRepo_iconCarrier">
                    <path
                      fill="#AAA"
                      fill-rule="evenodd"
                      d="M15.3007013,3.832 C16.1387013,2.818 16.7027013,1.405 16.5487013,0 C15.3407013,0.049 13.8797013,0.805 13.0137013,1.819 C12.2367013,2.717 11.5567013,4.154 11.7407013,5.531 C13.0867013,5.636 14.4627013,4.847 15.3007013,3.832 M18.3207013,12.75 C18.3547013,16.382 21.5067013,17.591 21.5417013,17.607 C21.5157013,17.692 21.0387013,19.329 19.8807013,21.02 C18.8807013,22.482 17.8427013,23.939 16.2067013,23.969 C14.5997013,23.998 14.0837013,23.016 12.2457013,23.016 C10.4097013,23.016 9.83570131,23.939 8.31370131,23.998 C6.73570131,24.058 5.53370131,22.417 4.52470131,20.961 C2.46370131,17.981 0.888701307,12.541 3.00370131,8.869 C4.05470131,7.045 5.93170131,5.89 7.96970131,5.861 C9.51970131,5.831 10.9827013,6.904 11.9307013,6.904 C12.8777013,6.904 14.6557013,5.614 16.5247013,5.803 C17.3077013,5.836 19.5037013,6.119 20.9147013,8.184 C20.8007013,8.254 18.2937013,9.714 18.3207013,12.75"
                    >
                    </path>
                  </g>
                </svg>
                macOS
              </div>
              <div
                class="download-btn"
                style="cursor: default; background: rgba(255, 255, 255, 0.03); border-style: dashed;"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  width="20"
                  height="100%"
                  viewBox="0 0 180 271"
                  version="1.1"
                  xml:space="preserve"
                  style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;"
                >
                  <g id="Group" transform="matrix(1,0,0,1,5.782,3.414)">
                    <g id="Path" transform="matrix(1,0,0,1,13,0)">
                      <g transform="matrix(1,0,0,1,24,0)">
                        <path
                          d="M31.758,46.916C32.498,23.429 24.586,9.582 1.841,0.435C-4.624,23.049 22.066,43.9 31.758,46.916Z"
                          style="fill:rgb(209,211,212);stroke:black;stroke-width:4.79px;"
                        ></path>
                      </g>
                      <path
