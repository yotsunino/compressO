                  </g>
                  <style id="squircle-everything-style">
                    * {
                      corner-shape: superellipse(1.333);
                    }
                  </style></svg
                >
                <code
                  id="brew-command"
                  style="font-size: 12px; padding: 2px 6px; border-radius: 3px; text-align: left; flex: 1;"
                  >brew install codeforreal1/tap/compresso</code
                >
                <button
                  id="copy-brew-btn"
                  class="copy-btn"
                  aria-label="Copy Homebrew command"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                    ></rect>
                    <path
                      d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                    ></path>
                  </svg>
                </button>
              </div>
              <a href={downloads.mac.aarch64} class="download-btn">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Apple Silicon <span class="arch-badge">aarch64</span>
              </a>
              <a href={downloads.mac.x64} class="download-btn">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
