    <script is:inline>
      const showAllBtn = document.getElementById("showAllBtn");
      const hiddenFeatures = document.querySelectorAll(".feature-hidden");

      showAllBtn?.addEventListener("click", () => {
        hiddenFeatures.forEach((feature) => {
          feature.classList.remove("feature-hidden");
        });
        showAllBtn.style.display = "none";
      });

      // Copy Homebrew command
      const copyBrewBtn = document.getElementById("copy-brew-btn");
      const brewCommand = document.getElementById("brew-command");

      copyBrewBtn?.addEventListener("click", async () => {
        const text = brewCommand.textContent;
        try {
          await navigator.clipboard.writeText(text);
          copyBrewBtn.classList.add("copied");
          setTimeout(() => {
            copyBrewBtn.classList.remove("copied");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });
    </script>
