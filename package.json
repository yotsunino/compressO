    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.16",
    "husky": "^8.0.1",
    "lint-staged": "^13.2.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vite": "^6.0.3",
    "vite-plugin-svgr": "^4.3.0"
